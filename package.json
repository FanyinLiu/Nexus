{
  "name": "nexus",
  "private": true,
  "version": "0.3.5",
  "description": "Nexus desktop AI companion built with Electron, React, and TypeScript.",
  "author": {
    "name": "FanyinLiu",
    "email": "nexus@fanyinliu.com"
  },
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "postinstall": "node scripts/setup-vendor.mjs",
    "download-models": "node scripts/download-models.mjs",
    "download-models:all": "node scripts/download-models.mjs",
    "download-models:lite": "node scripts/download-models.mjs --skip-asr",
    "doctor": "node scripts/nexus-doctor.mjs",
    "verify:first-run": "node scripts/verify-first-run.mjs",
    "message:send": "node scripts/send-message-webhook.mjs",
    "setup": "npm install && npm run build && node scripts/download-models.mjs",
    "dev": "vite",
    "electron:dev": "node scripts/electron-dev.mjs",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "lint:js": "eslint electron scripts --no-warn-ignored",
    "i18n:audit": "node scripts/i18n-audit.mjs",
    "ipc:audit": "node scripts/ipc-contract-audit.mjs",
    "storage:audit": "node scripts/storage-contract-audit.mjs",
    "heavy:audit": "node scripts/heavy-module-audit.mjs",
    "architecture:audit": "node scripts/architecture-boundary-audit.mjs",
    "source-size:audit": "node scripts/source-size-audit.mjs",
    "performance:baseline": "node scripts/performance-baseline.mjs",
    "companion-boundary:audit": "node scripts/companion-boundary-audit.mjs",
    "message-privacy:audit": "node scripts/message-privacy-audit.mjs",
    "desktop-context-privacy:audit": "node scripts/desktop-context-privacy-audit.mjs",
    "vault-security:audit": "node scripts/vault-security-audit.mjs",
    "error-redaction:audit": "node scripts/error-redaction-audit.mjs",
    "sqlite:smoke": "node scripts/sqlite-smoke.mjs",
    "sqlite:smoke:electron": "electron scripts/sqlite-electron-smoke.cjs",
    "sqlite:smoke:all": "npm run sqlite:smoke && npm run sqlite:smoke:electron",
    "distribution:audit": "node scripts/distribution-audit.mjs",
    "release:trust:audit": "node scripts/release-trust-audit.mjs",
    "release:signing:readiness": "node scripts/release-trust-audit.mjs --signed-readiness",
    "release:signing:gate": "node scripts/release-trust-audit.mjs --require-signed all",
    "release:signing:gate:mac": "node scripts/release-trust-audit.mjs --require-signed mac",
    "release:signing:gate:windows": "node scripts/release-trust-audit.mjs --require-signed windows",
    "pet:validate": "node scripts/validate-sprite-pet.mjs",
    "pet:create-kit": "node scripts/create-sprite-pet-creator-kit.mjs",
    "pet:assemble-kit": "node scripts/assemble-sprite-pet-creator-kit.mjs",
    "pet:audit": "node scripts/audit-sprite-pet-visual.mjs",
    "pet:generate-codex-style": "node scripts/generate-virtual-swordsman-pet.mjs",
    "pet:generate-swordsman": "node scripts/generate-virtual-swordsman-pet.mjs",
    "pet:import": "node scripts/import-sprite-pet.mjs",
    "pet:import-gallery": "node scripts/import-codex-pet-gallery.mjs",
    "pet:preview": "node scripts/preview-sprite-pet.mjs",
    "pet:presence-smoke": "npm run build && electron scripts/pet-presence-visual-smoke.cjs",
    "pet:scaffold": "node scripts/scaffold-sprite-pet.mjs",
    "pet:install-codex": "node scripts/install-codex-pet.mjs",
    "pet:export-runtime": "node scripts/export-sprite-pet-runtime.mjs",
    "test": "node --experimental-strip-types --test \"tests/*.test.ts\"",
    "preview": "vite preview",
    "start:app": "npm run build && electron .",
    "smoke": "npm run build && cross-env SMOKE_TEST=1 electron .",
    "smoke:packaged": "node scripts/packaged-smoke.mjs",
    "package": "npm run package:win",
    "package:dir": "npm run build && electron-builder --dir",
    "package:dir:smoke": "node -e \"require('fs').rmSync('release-smoke',{recursive:true,force:true})\" && npm run build && cross-env PACKAGED_SMOKE_RELEASE_DIR=release-smoke electron-builder --dir --publish never --config scripts/electron-builder.smoke.cjs && cross-env PACKAGED_SMOKE_RELEASE_DIR=release-smoke npm run smoke:packaged",
    "prepackage:win": "node scripts/download-models.mjs --skip-asr",
    "package:win": "npm run build && electron-builder --win nsis",
    "prepackage:win:signed": "node scripts/download-models.mjs --skip-asr",
    "package:win:signed": "npm run build && electron-builder --win nsis",
    "prepackage:mac": "node scripts/download-models.mjs --skip-asr",
    "package:mac": "npm run build && electron-builder --mac",
    "prepackage:linux": "node scripts/download-models.mjs --skip-asr",
    "package:linux": "npm run build && electron-builder --linux",
    "verify:pr": "tsc -b --force && npm run lint && npm test && npm run build && npm run storage:audit && npm run heavy:audit && npm run architecture:audit && npm run source-size:audit && npm run performance:baseline && npm run companion-boundary:audit && npm run message-privacy:audit && npm run desktop-context-privacy:audit && npm run vault-security:audit && npm run error-redaction:audit && npm run ipc:audit && npm run distribution:audit",
    "verify:release": "npm run verify:pr && npm run sqlite:smoke",
    "prerelease-check": "node scripts/prerelease-check.mjs"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@ricky0123/vad-web": "^0.0.30",
    "electron-updater": "^6.8.3",
    "onnxruntime-web": "^1.24.3",
    "pinyin-pro": "^3.28.1",
    "pixi-live2d-display": "^0.4.0",
    "pixi.js": "^6.5.10",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sharp": "^0.34.5",
    "sherpa-onnx-node": "^1.12.39",
    "tesseract.js": "^7.0.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@stryker-mutator/core": "^9.6.1",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "~6.0.1",
    "cross-env": "^10.1.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fast-check": "^4.7.0",
    "globals": "^17.5.0",
    "tailwindcss": "^4.2.4",
    "tinybench": "^6.0.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.59.0",
    "vite": "~8.0.9"
  },
  "overrides": {
    "axios": "^1.16.1",
    "fast-uri": "^3.1.2",
    "gh-pages": "^6.3.0",
    "ip-address": "^10.2.0",
    "minimatch@10.2.4": {
      "brace-expansion": "^5.0.6"
    },
    "protobufjs": "^7.6.1",
    "qs": "^6.15.2",
    "tmp": "^0.2.7"
  },
  "build": {
    "appId": "ai.factory.desktoppet",
    "productName": "Nexus",
    "directories": {
      "output": "release"
    },
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "scripts/omnivoice_server.py",
      "scripts/glm_asr_server.py",
      "scripts/send-message-webhook.mjs",
      "scripts/communication-adapters/**/*",
      "package.json",
      "!node_modules/onnxruntime-node/bin/napi-v3/win32/arm64/**",
      "!**/*.map",
      "!**/onnxruntime-web/dist/ort-wasm-simd-threaded.asyncify.*",
      "!**/onnxruntime-web/dist/ort-wasm-simd-threaded.jspi.*",
      "!**/onnxruntime-web/dist/ort.training.wasm.min.*",
      "!**/onnxruntime-web/dist/ort.webgl.*",
      "!**/onnxruntime-web/dist/ort.webgpu.*"
    ],
    "asarUnpack": [
      "node_modules/sherpa-onnx-node/**",
      "node_modules/sharp/**",
      "node_modules/@img/**",
      "scripts/omnivoice_server.py",
      "scripts/glm_asr_server.py",
      "scripts/send-message-webhook.mjs",
      "scripts/communication-adapters/**/*"
    ],
    "icon": "public/nexus-256.png",
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/nexus.ico",
      "asarUnpack": [
        "electron/mediaSession.ps1"
      ],
      "extraResources": [
        {
          "from": "sherpa-models",
          "to": "sherpa-models",
          "filter": [
            "**/*",
            "!_download.tar.bz2",
            "!**/*.tar.bz2",
            "!**/model.onnx",
            "!**/.git",
            "!**/.git/**",
            "!**/.gitattributes",
            "!**/test_wavs",
            "!**/test_wavs/**",
            "!**/export-onnx.py",
            "!**/README.md",
            "!**/LICENSE"
          ]
        },
        {
          "from": "public/vendor/vad/silero_vad_v5.onnx",
          "to": "silero_vad_v5.onnx"
        }
      ]
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "public/nexus-1024.png",
      "category": "public.app-category.utilities",
      "darkModeSupport": true,
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Nexus needs microphone access for voice conversations, wake word detection, and speech recognition.",
        "NSScreenCaptureUsageDescription": "Nexus uses screen capture for desktop awareness, allowing your AI companion to understand what you are working on.",
        "NSAppleEventsUsageDescription": "Nexus queries System Events to detect the app you're currently using and reads Now Playing info from Music and Spotify so your AI companion can respond to your context."
      },
      "extraResources": [
        {
          "from": "sherpa-models",
          "to": "sherpa-models",
          "filter": [
            "**/*",
            "!_download.tar.bz2",
            "!**/*.tar.bz2",
            "!**/model.onnx",
            "!**/.git",
            "!**/.git/**",
            "!**/.gitattributes",
            "!**/test_wavs",
            "!**/test_wavs/**",
            "!**/export-onnx.py",
            "!**/README.md",
            "!**/LICENSE"
          ]
        },
        {
          "from": "public/vendor/vad/silero_vad_v5.onnx",
          "to": "silero_vad_v5.onnx"
        }
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "public/nexus-256.png",
      "category": "Utility",
      "executableName": "nexus",
      "extraResources": [
        {
          "from": "sherpa-models",
          "to": "sherpa-models",
          "filter": [
            "**/*",
            "!_download.tar.bz2",
            "!**/*.tar.bz2",
            "!**/model.onnx",
            "!**/.git",
            "!**/.git/**",
            "!**/.gitattributes",
            "!**/test_wavs",
            "!**/test_wavs/**",
            "!**/export-onnx.py",
            "!**/README.md",
            "!**/LICENSE"
          ]
        },
        {
          "from": "public/vendor/vad/silero_vad_v5.onnx",
          "to": "silero_vad_v5.onnx"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "Nexus"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "FanyinLiu",
        "repo": "Nexus",
        "releaseType": "release"
      }
    ],
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  }
}
